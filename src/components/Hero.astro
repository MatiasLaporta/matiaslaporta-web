---
const stats = [
  { value: '+700% ROI', label: 'Promedio mensual' },
  { value: 'Hasta x10', label: 'en Ventas Online y Presencial' },
  { value: 'Sobre 20%', label: 'en Optimización de Procesos' },
];
---

<section id="top" class="relative overflow-hidden bg-dark flex min-h-screen items-center justify-center">
  <!-- Vanilla JS interactive node network -->
  <canvas id="network-canvas" class="absolute inset-0 w-full h-full z-0 opacity-60"></canvas>

  <!-- Soft accent glows above the canvas -->
  <div class="pointer-events-none absolute -top-40 -right-32 h-[520px] w-[520px] rounded-full bg-secondary/15 blur-3xl z-0"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-32 h-[520px] w-[520px] rounded-full bg-tertiary/10 blur-3xl z-0"></div>

  <div class="container-tight relative z-10 flex flex-col items-center text-center py-24">
    <span class="reveal inline-flex items-center gap-2 rounded-full border border-secondary/40 bg-secondary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-secondary backdrop-blur">
      <span class="h-1.5 w-1.5 rounded-full bg-secondary shadow-[0_0_10px_#f3cd74]"></span>
      Growth Architect
    </span>

    <h1 class="reveal mt-8 font-display text-5xl font-bold leading-[1.05] tracking-tight text-background sm:text-6xl lg:text-7xl max-w-5xl">
      Construimos el <span class="text-secondary [text-shadow:_0_0_30px_rgba(243,205,116,0.45)]">sistema de adquisición</span> que tu empresa necesita para escalar.
    </h1>

    <h2 class="reveal mt-6 text-xl leading-relaxed text-gray-300 max-w-3xl">
      Automatización, Inteligencia Artificial y Estrategia de Marketing y Ventas. Estructuramos la maquinaria completa para que dejes de depender de la suerte.
    </h2>

    <a
      href="https://calendar.app.google/2yt17PjZkAg5CcDE9"
      target="_blank"
      rel="noopener noreferrer"
      class="reveal btn-cyan mt-10 !px-8 !py-4 !text-base !font-bold focus:ring-offset-dark"
    >
      Auditar mi ecosistema
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>

    <dl class="reveal mt-16 grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-3 sm:gap-8 lg:mt-20">
      {stats.map((stat) => (
        <div class="hover-glow flex flex-col items-center rounded-2xl border border-white/10 bg-primary px-6 py-8 shadow-soft backdrop-blur">
          <dt class="font-display text-3xl font-bold leading-none text-secondary sm:text-4xl lg:text-5xl">
            {stat.value}
          </dt>
          <dd class="mt-3 text-sm font-medium uppercase tracking-[0.18em] text-background sm:text-base sm:normal-case sm:tracking-normal">
            {stat.label}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('network-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let particles = [];
    let mouse = { x: null, y: null };

    // Ajuste de tamaño
    function resize() {
      canvas.width = canvas.parentElement.offsetWidth;
      canvas.height = canvas.parentElement.offsetHeight;
    }
    window.addEventListener('resize', resize);

    // Interacción con el ratón
    canvas.parentElement.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    canvas.parentElement.addEventListener('mouseleave', () => {
      mouse.x = null;
      mouse.y = null;
    });

    // Clase Nodo
    class Particle {
      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.vx = (Math.random() - 0.5) * 1.5;
        this.vy = (Math.random() - 0.5) * 1.5;
        this.radius = Math.random() * 2 + 1;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = '#00E5FF';
        ctx.fill();
      }
    }

    // Inicialización y Animación
    function init() {
      resize();
      particles = [];
      for (let i = 0; i < 70; i++) {
        particles.push(new Particle());
      }
      animate();
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Dibujar nodos
      particles.forEach(p => {
        p.update();
        p.draw();
      });

      // Dibujar conexiones
      for (let i = 0; i < particles.length; i++) {
        // Conexión con el ratón
        if (mouse.x != null) {
          let dxMouse = particles[i].x - mouse.x;
          let dyMouse = particles[i].y - mouse.y;
          let distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
          if (distMouse < 180) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0, 229, 255,${0.5 * (1 - distMouse/180)})`;
            ctx.lineWidth = 1.5;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.stroke();
          }
        }
        // Conexión entre nodos
        for (let j = i; j < particles.length; j++) {
          let dx = particles[i].x - particles[j].x;
          let dy = particles[i].y - particles[j].y;
          let dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0, 229, 255,${0.2 * (1 - dist/120)})`;
            ctx.lineWidth = 1;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animate);
    }

    init();
  });
</script>
