---
const nav = [
  { label: 'Problema', href: '#problema' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Comparación', href: '#comparacion' },
  { label: 'Servicios', href: '#servicios' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-40 border-b border-primary/10 bg-background transition-colors duration-300"
>
  <div class="container-tight flex h-16 items-center justify-between">
    <a href="#top" class="group flex items-center">
      <img src="/Logo.png" alt="Matías Laporta" class="h-10 w-auto transition group-hover:scale-105" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Principal" class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-dark transition-colors hover:text-accent"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="https://calendar.app.google/2yt17PjZkAg5CcDE9" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex btn-primary !py-2 !px-5 text-xs sm:text-sm">
      Agendar Reunión
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-dark"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute left-0 right-0 top-full border-b border-primary/10 bg-background px-4 pb-4 pt-2 shadow-lg"
  >
    <nav aria-label="Principal móvil" class="flex flex-col">
      {nav.map((item) => (
        <a
          href={item.href}
          class="block rounded-md px-3 py-3 text-base font-medium text-dark transition-colors hover:bg-gray-100 hover:text-accent"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="https://calendar.app.google/2yt17PjZkAg5CcDE9" target="_blank" rel="noopener noreferrer" class="btn-primary mt-3 w-full justify-center">
      Agendar Reunión
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // Background shifts from palette white to light gray as soon as the user scrolls
  function onScroll() {
    if (!header) return;
    header.classList.toggle('scrolled', window.scrollY > 8);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile hamburger dropdown
  function setMenu(open) {
    if (!menu || !toggle || !iconOpen || !iconClose) return;
    menu.classList.toggle('hidden', !open);
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  }
  toggle?.addEventListener('click', () => {
    setMenu(menu?.classList.contains('hidden') ?? false);
  });
  // Close the menu after tapping any link or the CTA
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
</script>
