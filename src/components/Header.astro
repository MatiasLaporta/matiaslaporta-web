---
const nav = [
  { label: 'Problema', href: '#problema' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Comparación', href: '#comparacion' },
  { label: 'Servicios', href: '#servicios' },
];
---

<header class="sticky top-0 z-40 border-b border-primary/10 bg-tertiary backdrop-blur-lg">
  <div class="container-tight flex h-16 items-center justify-between">
    <a href="#top" class="group flex items-center gap-2.5">
      <img src="/Logo.png" alt="Matías Laporta" class="h-10 w-auto transition group-hover:scale-105" />
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-sm font-bold uppercase tracking-[0.14em] text-secondary">Asesoría Consultiva</span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-primary">Growth Architect</span>
      </span>
    </a>

    <nav aria-label="Principal" class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-gray-200 transition-colors hover:text-secondary"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="#contacto" class="btn-primary !py-2 !px-5 text-xs sm:text-sm">
      Agendar Reunión Exploratoria
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</header>
