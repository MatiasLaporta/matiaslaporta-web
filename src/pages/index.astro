---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import About from '../components/About.astro';
import Comparison from '../components/Comparison.astro';
import Services from '../components/Services.astro';
import TestimonialMarquee from '../components/TestimonialMarquee.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Matías Laporta | Arquitecto de Adquisición y Crecimiento"
  description="Construimos el motor de adquisición y ventas que tu empresa necesita para escalar: embudos automatizados, IA, ecosistemas CRM y dirección comercial táctica."
  canonical="https://matiaslaporta.com/"
>
  <Header />
  <main>
    <Hero />
    <PainPoints />
    <About />
    <Comparison />
    <Services />
    <TestimonialMarquee />
    <CTA />
  </main>
  <Footer />
</Layout>
