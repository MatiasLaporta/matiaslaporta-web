---

<Layout
  title="Matías Laporta | Asesoría Consultiva"
  description="Arquitecto de adquisición y crecimiento. Diseño la infraestructura comercial completa para empresas que necesitan escalar de forma predecible."
  canonical="https://tarjeta.matiaslaporta.com/"
>
  <main class="relative min-h-screen overflow-hidden bg-dark">
    <!-- Red de nodos interactiva (cian) -->
    <canvas id="tarjeta-canvas" class="absolute inset-0 z-0 h-full w-full opacity-60"></canvas>

    <!-- Glows suaves de marca -->
    <div class="pointer-events-none absolute -top-40 -right-32 z-0 h-[520px] w-[520px] rounded-full bg-secondary/15 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-40 -left-32 z-0 h-[520px] w-[520px] rounded-full bg-tertiary/10 blur-3xl"></div>

    <div class="relative z-10 mx-auto flex min-h-screen w-full max-w-md flex-col items-center px-5 py-12 sm:py-16 md:max-w-[30rem]">
      <!-- Header: foto + logo + bajada -->
      <header class="reveal flex flex-col items-center text-center">
        <img
          src="/perfil.png"
          alt="Matías Laporta"
          class="h-32 w-32 rounded-full object-cover ring-4 ring-secondary shadow-[0_0_45px_-8px_rgba(243,205,116,0.55)]"
        />
        <img src="/nombre.png" alt="Matías Laporta" class="mt-6 h-12 w-auto" />
        <p class="mt-5 max-w-sm text-sm leading-relaxed sm:text-base md:max-w-none">
          <span class="text-secondary [text-shadow:_0_0_20px_rgba(243,205,116,0.35)]">Arquitecto de adquisición y crecimiento.</span>
          <span class="mt-2 block text-background">Diseño la infraestructura comercial completa para empresas que necesitan escalar de forma predecible.</span>
        </p>
      </header>

      <!-- Botones pequeños horizontales -->
      <nav aria-label="Contacto directo" class="reveal mt-8 flex items-center justify-center gap-4">
        {compact.map((b) => (
          <a
            href={b.href}
            target={b.href.startsWith('http') ? '_blank' : undefined}
            rel={b.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            aria-label={b.label}
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-background shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_24px_-4px_rgba(243,205,116,0.6)] focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-dark"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill={b.fill ? 'currentColor' : 'none'}
              stroke={b.fill ? 'none' : 'currentColor'}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={b.icon}
            />
          </a>
        ))}

        <!-- Guardar contacto (vCard): solo símbolo -->
        <button
          id="save-contact"
          type="button"
          aria-label="Guardar contacto"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-background shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_24px_-4px_rgba(243,205,116,0.6)] focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-dark"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M19 8v6M22 11h-6" />
          </svg>
        </button>
      </nav>

      <!-- Botones grandes verticales -->
      <div class="reveal mt-8 flex w-full flex-col gap-4">
        {links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            onclick={`if(typeof gtag !== 'undefined') gtag('event', 'click_boton_tarjeta', { 'nombre_boton': '${l.track}' });`}
            class={`link-card group flex w-full items-center gap-4 rounded-2xl border border-secondary px-5 py-4 text-background transition-all duration-300 ${l.highlight ? 'link-card-hl' : 'bg-transparent'}`}
          >
            <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center text-secondary">
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill={l.fill ? 'currentColor' : 'none'}
                stroke={l.fill ? 'none' : 'currentColor'}
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={l.icon}
              />
            </span>
            <span class="flex-1 text-center text-base font-semibold">{l.label}</span>
            <span class="h-6 w-6 flex-shrink-0" aria-hidden="true"></span>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <footer class="reveal mt-auto pt-12 text-center">
        <p class="text-sm font-medium leading-relaxed md:text-base">
          <span class="text-background">Revisemos en una sesión tu ecosistema comercial.</span>
          <span class="mt-1 block text-secondary [text-shadow:_0_0_20px_rgba(243,205,116,0.35)] md:mt-0">Si no hay fit, te digo exactamente dónde mirar.</span>
        </p>

        <!-- Compartir (botón + desplegable) -->
        <div class="relative mt-6 inline-block text-left">
          <button
            id="share-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="share-panel"
            onclick="if(typeof gtag !== 'undefined') gtag('event', 'click_boton_tarjeta', { 'nombre_boton': 'compartir' });"
            class="link-card group inline-flex items-center justify-center gap-2 rounded-full border border-secondary bg-transparent px-6 py-2.5 text-sm font-semibold text-background transition-all duration-300"
          >
            <svg class="h-4 w-4 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" />
              <path d="m8.59 13.51 6.83 3.98M15.41 6.51l-6.82 3.98" />
            </svg>
            Compartir
          </button>

          <div
            id="share-panel"
            class="absolute bottom-full left-1/2 z-20 mb-3 hidden w-72 -translate-x-1/2 rounded-2xl border border-secondary/30 bg-primary/95 p-5 text-left shadow-[0_10px_40px_-8px_rgba(0,0,0,0.6)] backdrop-blur"
          >
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-300">Compartir tarjeta</p>
            <div class="mt-4 grid grid-cols-3 gap-y-4">
              {shareTargets.map((s) => (
                <a
                  href={s.href ?? '#'}
                  id={s.id}
                  target={s.href && s.href.startsWith('http') ? '_blank' : undefined}
                  rel={s.href && s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  aria-label={`Compartir por ${s.label}`}
                  class="group flex flex-col items-center gap-1.5"
                >
                  <span class={`flex h-12 w-12 items-center justify-center rounded-full ${s.bg} text-white transition-transform duration-200 group-hover:scale-105`}>
                    <svg
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill={s.fill ? 'currentColor' : 'none'}
                      stroke={s.fill ? 'none' : 'currentColor'}
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      set:html={s.icon}
                    />
                  </span>
                  <span class="text-xs text-gray-300">{s.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <p class="mt-5 text-xs text-gray-400">&copy; 2026 Matías Laporta. Todos los derechos reservados.</p>
        <p class="mt-1 text-xs text-gray-400">Santiago, Chile</p>
      </footer>
    </div>
  </main>
</Layout>

<script>
  // ---- Guardar contacto (vCard) ----
  const saveBtn = document.getElementById('save-contact');
  saveBtn?.addEventListener('click', () => {
    const vcard = [
      'BEGIN:VCARD',
      'VERSION:3.0',
      'N:Laporta;Matías;;;',
      'FN:Matías Laporta',
      'TEL;TYPE=CELL,VOICE:+56983306813',
      'EMAIL;TYPE=WORK,INTERNET:asesor@matiaslaporta.com',
      'URL:https://matiaslaporta.com/',
      'END:VCARD',
    ].join('\r\n');

    const blob = new Blob([vcard], { type: 'text/vcard;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'Matias-Laporta.vcf';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  // ---- Compartir (desplegable) ----
  const shareToggle = document.getElementById('share-toggle');
  const sharePanel = document.getElementById('share-panel');

  function setSharePanel(open) {
    if (!sharePanel || !shareToggle) return;
    sharePanel.classList.toggle('hidden', !open);
    shareToggle.setAttribute('aria-expanded', String(open));
  }
  shareToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setSharePanel(sharePanel?.classList.contains('hidden') ?? false);
  });
  // Cerrar al hacer click fuera o con Escape
  document.addEventListener('click', (e) => {
    if (!sharePanel || sharePanel.classList.contains('hidden')) return;
    if (!sharePanel.contains(e.target) && e.target !== shareToggle) setSharePanel(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setSharePanel(false);
  });

  // Copiar enlace al portapapeles
  const copyLink = document.getElementById('copy-link');
  const copyLabel = copyLink?.querySelector('span:last-child');
  copyLink?.addEventListener('click', async (e) => {
    e.preventDefault();
    try {
      await navigator.clipboard.writeText('https://matiaslaporta.com/tarjeta');
      if (copyLabel) {
        const original = copyLabel.textContent;
        copyLabel.textContent = '¡Copiado!';
        setTimeout(() => { copyLabel.textContent = original; }, 1500);
      }
    } catch {
      /* clipboard no disponible: no hacemos nada */
    }
  });

  // ---- Red de nodos interactiva (cian) ----
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('tarjeta-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let particles = [];
    let mouse = { x: null, y: null };

    function resize() {
      canvas.width = canvas.parentElement.offsetWidth;
      canvas.height = canvas.parentElement.offsetHeight;
    }
    window.addEventListener('resize', resize);

    canvas.parentElement.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    canvas.parentElement.addEventListener('mouseleave', () => {
      mouse.x = null;
      mouse.y = null;
    });

    class Particle {
      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.vx = (Math.random() - 0.5) * 1.5;
        this.vy = (Math.random() - 0.5) * 1.5;
        this.radius = Math.random() * 2 + 1;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = '#00E5FF';
        ctx.fill();
      }
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < 70; i++) particles.push(new Particle());
      animate();
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => {
        p.update();
        p.draw();
      });
      for (let i = 0; i < particles.length; i++) {
        if (mouse.x != null) {
          let dxM = particles[i].x - mouse.x;
          let dyM = particles[i].y - mouse.y;
          let distM = Math.sqrt(dxM * dxM + dyM * dyM);
          if (distM < 180) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0, 229, 255,${0.5 * (1 - distM / 180)})`;
            ctx.lineWidth = 1.5;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.stroke();
          }
        }
        for (let j = i; j < particles.length; j++) {
          let dx = particles[i].x - particles[j].x;
          let dy = particles[i].y - particles[j].y;
          let dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0, 229, 255,${0.2 * (1 - dist / 120)})`;
            ctx.lineWidth = 1;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animate);
    }

    init();
  });
</script>

